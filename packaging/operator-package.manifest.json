{
  "schemaVersion": 1,
  "packageName": "ExtrusionWebConsole",
  "packageRoot": "ExtrusionWebConsole",
  "requiredPaths": [
    "backend/app",
    "backend/requirements.txt",
    "frontend/dist/index.html",
    "launcher/start_web_console.ps1",
    "launcher/start_web_console.bat",
    "launcher/install_shortcuts.ps1",
    "launcher/install_shortcuts.bat",
    "README.md",
    "CHANGELOG.md",
    "VERSION"
  ],
  "includeAllowlist": [
    {
      "source": "backend/app",
      "target": "backend/app",
      "type": "directory",
      "required": true
    },
    {
      "source": "backend/requirements.txt",
      "target": "backend/requirements.txt",
      "type": "file",
      "required": true
    },
    {
      "source": "frontend/dist",
      "target": "frontend/dist",
      "type": "directory",
      "required": true
    },
    {
      "source": "launcher",
      "target": "launcher",
      "type": "directory",
      "required": true
    },
    {
      "source": "docs/operator_package_runtime_note.md",
      "target": "README.md",
      "type": "file",
      "required": true
    },
    {
      "source": "CHANGELOG.md",
      "target": "CHANGELOG.md",
      "type": "file",
      "required": true
    },
    {
      "source": "VERSION",
      "target": "VERSION",
      "type": "file",
      "required": true
    },
    {
      "source": "docs/operator_package_runtime_note.md",
      "target": "docs/operator_package_runtime_note.md",
      "type": "file",
      "required": true
    },
    {
      "source": ".venv",
      "target": ".venv",
      "type": "directory",
      "required": true,
      "allowIncompleteSwitch": "AllowIncompleteRuntime",
      "exclude": [
        "__pycache__",
        "*.pyc",
        "*.pyo",
        ".pytest_cache",
        "test",
        "tests",
        "testing",
        "testsuite"
      ],
      "preserveMetadata": [
        "*.dist-info",
        "METADATA",
        "RECORD",
        "WHEEL",
        "entry_points.txt",
        "LICENSE*",
        "NOTICE*",
        "COPYING*"
      ]
    }
  ],
  "excludeDenylist": [
    ".git",
    ".gstack",
    ".agents",
    ".codex",
    ".bkit-codex",
    ".pytest_cache",
    "frontend/node_modules",
    "frontend/src",
    "frontend/qa",
    "tests",
    ".env*",
    "logs",
    "*.db",
    "*.db-shm",
    "*.db-wal",
    "*.sqlite",
    "*.sqlite3",
    "*.log",
    "*.csv",
    "__pycache__",
    "*.pyc",
    "*.pyo",
    "tmp",
    "temp"
  ],
  "operatorReadyChecks": [
    "frontend/dist/index.html",
    ".venv/Scripts/python.exe",
    "launcher/start_web_console.ps1",
    "launcher/install_shortcuts.ps1"
  ],
  "redactionChecks": [
    "database-url-marker",
    "authorization-bearer-marker",
    "credential-like-marker",
    "jwt-like-marker",
    "service-role-assignment-marker",
    "anon-key-assignment-marker",
    "timestamp-style-csv-marker",
    "operational-filename-family-marker",
    "windows-absolute-path-marker"
  ],
  "smokeChecks": [
    "packaged .venv python imports backend.app.main",
    "launcher/start_web_console.ps1 -CheckOnly",
    "launcher/install_shortcuts.ps1 -CheckOnly",
    "GET /",
    "GET /upload",
    "GET /logs",
    "GET /settings",
    "GET /api/health",
    "GET /api/config",
    "GET /api/audit?limit=1",
    "mutating API without local token returns 403",
    "operator API docs routes return 404"
  ],
  "buildMetadata": {
    "sourceCommit": "filled-by-assembly",
    "createdUtc": "filled-by-assembly",
    "frontendMode": "filled-by-assembly",
    "frontendBuildInfoPath": "frontend/dist/frontend-build-info.json",
    "supportedFrontendModes": [
      "mock",
      "api"
    ],
    "zipSha256": "filled-by-assembly-when-created"
  }
}
